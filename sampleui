<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Events – Sidebar WebPart</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:           #f5f3ef;
    --surface:      #ffffff;
    --surface2:     #f0ede8;
    --border:       #e2ddd6;
    --accent:       #c0392b;
    --accent2:      #e8d5b7;
    --text-primary: #1a1612;
    --text-secondary:#6b6259;
    --text-muted:   #9e9088;
    --radius:       10px;
    --shadow:       0 2px 12px rgba(0,0,0,0.08);
    --shadow-hover: 0 8px 28px rgba(0,0,0,0.13);
    --font-display: 'DM Serif Display', Georgia, serif;
    --font-body:    'DM Sans', system-ui, sans-serif;
    --t:            0.22s cubic-bezier(0.4,0,0.2,1);
  }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text-primary);
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 32px 16px 48px;
  }

  /* ── SIDEBAR WEBPART SHELL ───────────────────────── */
  .webpart {
    background: var(--surface);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    width: 100%;
    max-width: 360px;   /* sidebar max width */
    overflow: hidden;
  }

  /* ── HEADER ──────────────────────────────────────── */
  .webpart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px 11px;
    border-bottom: 1px solid var(--border);
    gap: 10px;
  }

  .webpart-title {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--text-primary);
    line-height: 1.2;
    white-space: nowrap;
  }
  .webpart-title span { color: var(--accent); font-style: italic; }

  /* ── VIEW TOGGLE ─────────────────────────────────── */
  .view-toggle {
    display: flex;
    gap: 2px;
    background: var(--surface2);
    border-radius: 7px;
    padding: 3px;
    flex-shrink: 0;
  }

  .view-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px 8px;
    border-radius: 5px;
    color: var(--text-muted);
    transition: var(--t);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .view-btn:hover  { color: var(--text-primary); background: var(--border); }
  .view-btn.active { background: var(--surface); color: var(--accent); box-shadow: 0 1px 4px rgba(0,0,0,0.10); }

  /* ── EVENTS CONTAINER ────────────────────────────── */
  .events-container { padding: 12px 14px 16px; }

  /* ── LIST VIEW ───────────────────────────────────── */
  .events-list { display: flex; flex-direction: column; }

  .event-list-item {
    display: grid;
    grid-template-columns: 50px 1fr auto;
    gap: 0 11px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: var(--t);
  }
  .event-list-item:last-child { border-bottom: none; }
  .event-list-item:hover .event-list-title { color: var(--accent); }

  .date-badge {
    background: var(--accent);
    color: #fff;
    border-radius: 7px;
    text-align: center;
    padding: 5px 0;
    flex-shrink: 0;
  }
  .date-badge .month {
    display: block;
    font-size: 8.5px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    opacity: 0.82;
    line-height: 1;
  }
  .date-badge .day {
    display: block;
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.1;
  }

  .list-info { min-width: 0; }

  .event-list-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color var(--t);
    line-height: 1.3;
  }

  .event-list-loc {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .event-list-loc svg { flex-shrink: 0; opacity: 0.7; }

  /* ── GRID VIEW — adaptive 2 or 3 cols ───────────── */
  /*
    Container is ≤360px wide; padding = 14px each side → inner = ≤332px
    3 cols → each card ≈ 100px  (fits when inner ≥ 300px, i.e. viewport ≥ 328px)
    2 cols → each card ≈ 152px  (fallback for narrow viewports)
    Using CSS container queries so the grid reacts to the webpart width,
    not the viewport — perfect for any SharePoint zone width.
  */
  .events-grid-wrap {
    container-type: inline-size;
    container-name: grid-wrap;
  }

  .events-grid {
    display: grid;
    gap: 8px;
    /* default: 2 columns */
    grid-template-columns: repeat(2, 1fr);
  }

  /* 3 columns when container ≥ 300px */
  @container grid-wrap (min-width: 300px) {
    .events-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .event-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    transition: box-shadow var(--t), transform var(--t);
  }
  .event-card:hover { box-shadow: var(--shadow-hover); transform: translateY(-2px); }

  .card-top {
    background: linear-gradient(135deg, var(--accent) 0%, #a93226 100%);
    padding: 10px 10px 8px;
    position: relative;
  }
  .card-top .month-lbl {
    font-size: 8.5px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.82);
    line-height: 1;
  }
  .card-top .day-lbl {
    font-family: var(--font-display);
    font-size: 28px;
    color: #fff;
    line-height: 1;
    margin-top: 1px;
  }
  .card-info-btn {
    position: absolute;
    top: 7px;
    right: 7px;
    background: rgba(255,255,255,0.22);
    border: none;
    border-radius: 50%;
    width: 22px;
    height: 22px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: var(--t);
  }
  .card-info-btn:hover { background: rgba(255,255,255,0.42); }

  .card-body { padding: 8px 9px 10px; }
  .card-title {
    font-size: 11.5px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-loc {
    display: flex;
    align-items: center;
    gap: 2px;
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── COMPACT VIEW ────────────────────────────────── */
  .events-compact { display: flex; flex-direction: column; }

  .event-compact-item {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 7px 0;
    border-bottom: 1px dashed var(--border);
    cursor: pointer;
    transition: var(--t);
  }
  .event-compact-item:last-child { border-bottom: none; }
  .event-compact-item:hover .compact-title { color: var(--accent); }

  .compact-pill {
    background: var(--accent2);
    color: var(--accent);
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 2px 7px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .compact-info { min-width: 0; flex: 1; }
  .compact-title {
    font-size: 12.5px;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color var(--t);
    line-height: 1.3;
  }
  .compact-loc {
    font-size: 10.5px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 1px;
  }

  /* ── SHARED INFO BUTTON ──────────────────────────── */
  .info-btn {
    background: var(--surface2);
    border: none;
    border-radius: 50%;
    width: 26px;
    height: 26px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    flex-shrink: 0;
    transition: var(--t);
    margin-left: auto;
  }
  .info-btn:hover { background: var(--accent); color: #fff; }

  /* ── HIDDEN / VISIBLE ────────────────────────────── */
  [data-view] { display: none; }
  [data-view].active { display: flex; flex-direction: column; }
  [data-view="grid"].active { display: block; } /* let inner grid handle layout */

  /* ── POPOVER ─────────────────────────────────────── */
  .popover-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    pointer-events: none;
  }
  .popover-overlay.active { pointer-events: all; }

  .popover {
    position: fixed;
    z-index: 9999;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.18);
    width: 270px;
    max-width: calc(100vw - 24px);
    opacity: 0;
    transform: scale(0.94) translateY(6px);
    transition: opacity 0.18s ease, transform 0.18s ease;
    pointer-events: none;
    overflow: hidden;
  }
  .popover.visible {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: all;
  }

  .pop-top {
    background: linear-gradient(135deg, var(--accent) 0%, #a93226 100%);
    padding: 14px 14px 11px;
    position: relative;
  }
  .pop-close {
    position: absolute;
    top: 9px; right: 9px;
    background: rgba(255,255,255,0.22);
    border: none;
    border-radius: 50%;
    width: 24px; height: 24px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 13px;
    transition: var(--t);
  }
  .pop-close:hover { background: rgba(255,255,255,0.42); }

  .pop-date-lbl {
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(255,255,255,0.78);
  }
  .pop-title {
    font-family: var(--font-display);
    font-size: 17px; color: #fff;
    margin-top: 3px; line-height: 1.25;
    padding-right: 24px;
  }

  .pop-body { padding: 12px 14px 14px; display: flex; flex-direction: column; gap: 9px; }
  .pop-row { display: flex; align-items: flex-start; gap: 7px; font-size: 12.5px; color: var(--text-secondary); }
  .pop-row svg { flex-shrink: 0; margin-top: 1px; color: var(--accent); }
  .pop-row strong {
    display: block; font-weight: 600; color: var(--text-primary);
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 2px;
  }
</style>
</head>
<body>

<!-- ── SIDEBAR WEBPART ───────────────────────────────── -->
<div class="webpart">
  <div class="webpart-header">
    <h2 class="webpart-title">Upcoming <span>Events</span></h2>
    <div class="view-toggle">
      <button class="view-btn active" onclick="switchView('list',this)" title="List view">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="1" y1="4" x2="15" y2="4"/><line x1="1" y1="8" x2="15" y2="8"/><line x1="1" y1="12" x2="15" y2="12"/></svg>
      </button>
      <button class="view-btn" onclick="switchView('grid',this)" title="Grid view">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="1" y="1" width="6" height="6"/><rect x="9" y="1" width="6" height="6"/><rect x="1" y="9" width="6" height="6"/><rect x="9" y="9" width="6" height="6"/></svg>
      </button>
      <button class="view-btn" onclick="switchView('compact',this)" title="Compact view">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="1" y1="3" x2="15" y2="3"/><line x1="1" y1="7" x2="15" y2="7"/><line x1="1" y1="11" x2="15" y2="11"/><line x1="1" y1="15" x2="15" y2="15"/></svg>
      </button>
    </div>
  </div>

  <div class="events-container">

    <!-- LIST -->
    <div data-view="list" class="events-list active" id="view-list"></div>

    <!-- GRID (container-query wrapper) -->
    <div data-view="grid">
      <div class="events-grid-wrap">
        <div class="events-grid" id="view-grid"></div>
      </div>
    </div>

    <!-- COMPACT -->
    <div data-view="compact" class="events-compact" id="view-compact"></div>

  </div>
</div>

<!-- ── POPOVER ───────────────────────────────────────── -->
<div class="popover-overlay" id="popOverlay" onclick="closePopover()"></div>
<div class="popover" id="popover">
  <div class="pop-top">
    <button class="pop-close" onclick="closePopover()">✕</button>
    <div class="pop-date-lbl" id="pop-date"></div>
    <div class="pop-title"    id="pop-title"></div>
  </div>
  <div class="pop-body">
    <div class="pop-row">
      <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 1C5.24 1 3 3.24 3 6c0 4 5 9 5 9s5-5 5-9c0-2.76-2.24-5-5-5z"/><circle cx="8" cy="6" r="1.5"/></svg>
      <div><strong>Location</strong><span id="pop-loc"></span></div>
    </div>
    <div class="pop-row">
      <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="1" y="2" width="14" height="13" rx="2"/><line x1="5" y1="1" x2="5" y2="4"/><line x1="11" y1="1" x2="11" y2="4"/><line x1="1" y1="7" x2="15" y2="7"/></svg>
      <div><strong>Date</strong><span id="pop-fulldate"></span></div>
    </div>
    <div class="pop-row">
      <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="8" cy="8" r="7"/><line x1="8" y1="7" x2="8" y2="12"/><circle cx="8" cy="4.5" r="0.5" fill="currentColor" stroke="none"/></svg>
      <div><strong>Description</strong><span id="pop-desc"></span></div>
    </div>
  </div>
</div>

<script>
const EVENTS = [
  { month:'APR', day:'03', year:2025, fullDate:'Thursday, April 3, 2025',   title:'Annual Strategy Kickoff',    location:'Main Conference Hall, Bldg A', description:'Kick off the annual strategic planning cycle with all department leads. Review previous year results and align on OKRs.' },
  { month:'APR', day:'11', year:2025, fullDate:'Friday, April 11, 2025',    title:'UX Design Workshop',         location:'Design Studio, Floor 2',       description:'Hands-on workshop covering UX research methods, prototyping, and design system updates. Open to all product team members.' },
  { month:'APR', day:'18', year:2025, fullDate:'Friday, April 18, 2025',    title:'Q1 All-Hands Meeting',       location:'Auditorium, HQ',               description:'Company-wide all-hands featuring Q1 updates, team shoutouts, and a live Q&A with leadership.' },
  { month:'MAY', day:'02', year:2025, fullDate:'Friday, May 2, 2025',       title:'New Hire Orientation',       location:'Training Room 101',            description:'Welcome session for May joiners. Covers culture, tools, benefits overview, and networking lunch.' },
  { month:'MAY', day:'15', year:2025, fullDate:'Thursday, May 15, 2025',    title:'Tech Innovation Summit',     location:'Convention Centre, Downtown',   description:'Day-long summit on emerging tech: AI, cloud, and security. External speakers, demos, and breakout sessions.' },
  { month:'JUN', day:'06', year:2025, fullDate:'Friday, June 6, 2025',      title:'Mid-Year Performance Review',location:'Online / Teams',               description:'Mid-year check-in for employees and managers to review H1 progress and update development plans for H2.' },
];

/* ── SVG helpers ── */
const pinSVG  = `<svg width="10" height="10" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 1C5.24 1 3 3.24 3 6c0 4 5 9 5 9s5-5 5-9c0-2.76-2.24-5-5-5z"/><circle cx="8" cy="6" r="1.5"/></svg>`;
const infoSVG = `<svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="8" cy="8" r="7"/><line x1="8" y1="7" x2="8" y2="12"/><circle cx="8" cy="4.5" r="0.5" fill="currentColor" stroke="none"/></svg>`;

/* ── Build HTML ── */
function listHTML(ev, i) {
  return `<div class="event-list-item" onclick="openPop(${i},this)">
    <div class="date-badge">
      <span class="month">${ev.month}</span>
      <span class="day">${ev.day}</span>
    </div>
    <div class="list-info">
      <div class="event-list-title">${ev.title}</div>
      <div class="event-list-loc">${pinSVG} ${ev.location}</div>
    </div>
    <button class="info-btn" onclick="event.stopPropagation();openPop(${i},this)">${infoSVG}</button>
  </div>`;
}

function gridHTML(ev, i) {
  return `<div class="event-card" onclick="openPop(${i},this)">
    <div class="card-top">
      <button class="card-info-btn" onclick="event.stopPropagation();openPop(${i},this)">${infoSVG}</button>
      <div class="month-lbl">${ev.month} ${ev.year}</div>
      <div class="day-lbl">${ev.day}</div>
    </div>
    <div class="card-body">
      <div class="card-title">${ev.title}</div>
      <div class="card-loc">${pinSVG} ${ev.location}</div>
    </div>
  </div>`;
}

function compactHTML(ev, i) {
  return `<div class="event-compact-item" onclick="openPop(${i},this)">
    <div class="compact-pill">${ev.month} ${ev.day}</div>
    <div class="compact-info">
      <div class="compact-title">${ev.title}</div>
      <div class="compact-loc">${ev.location}</div>
    </div>
    <button class="info-btn" onclick="event.stopPropagation();openPop(${i},this)">${infoSVG}</button>
  </div>`;
}

document.getElementById('view-list').innerHTML    = EVENTS.map(listHTML).join('');
document.getElementById('view-grid').innerHTML    = EVENTS.map(gridHTML).join('');
document.getElementById('view-compact').innerHTML = EVENTS.map(compactHTML).join('');

/* ── View switching ── */
function switchView(view, btn) {
  document.querySelectorAll('[data-view]').forEach(el => el.classList.remove('active'));
  document.querySelector(`[data-view="${view}"]`).classList.add('active');
  document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

/* ── Popover ── */
function openPop(idx, trigger) {
  const ev = EVENTS[idx];
  document.getElementById('pop-date').textContent    = `${ev.month} ${ev.day}, ${ev.year}`;
  document.getElementById('pop-title').textContent   = ev.title;
  document.getElementById('pop-loc').textContent     = ev.location;
  document.getElementById('pop-fulldate').textContent= ev.fullDate;
  document.getElementById('pop-desc').textContent    = ev.description;

  const pop = document.getElementById('popover');
  const rect = trigger.getBoundingClientRect();
  const W = 270, H = 250;
  let left = rect.left + rect.width / 2 - W / 2;
  let top  = rect.bottom + 8;
  if (left + W > window.innerWidth - 12) left = window.innerWidth - W - 12;
  if (left < 12) left = 12;
  if (top + H > window.innerHeight - 12) top = rect.top - H - 8;

  pop.style.left = left + 'px';
  pop.style.top  = top  + 'px';
  document.getElementById('popOverlay').classList.add('active');
  pop.classList.add('visible');
}

function closePopover() {
  document.getElementById('popover').classList.remove('visible');
  document.getElementById('popOverlay').classList.remove('active');
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closePopover(); });
</script>
</body>
</html>