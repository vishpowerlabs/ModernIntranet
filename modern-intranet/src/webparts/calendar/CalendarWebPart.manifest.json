            },
            "iconImageUrl": "../../assets/calendar-custom.png",
            "properties": {
                "source": "spList",
                "siteUrl": "",
                "listId": "",
                "titleColumn": "Title",
                "dateColumn": "CalEventDate",
                "endDateColumn": "CalEndDate",
                "locationColumn": "CalLocation",
